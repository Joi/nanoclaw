+  const displayName = senderName || phone;
+
+  // Check template folder exists
+  const templateDir = path.join(GROUPS_DIR, SIGNAL_DEFAULT_TIER);
+  const templateClaudeMd = path.join(templateDir, 'CLAUDE.md');
