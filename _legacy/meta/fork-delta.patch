+  }),
+);
+
+vi.mock("fs", () => ({
+  default: {
+    createReadStream: mockCreateReadStream,
+    mkdirSync: vi.fn(),
+    writeFileSync: vi.fn(),
+    readFileSync: mockReadFileSync,
+    appendFileSync: vi.fn(),
