+    logger.warn(
+      { template: SIGNAL_DEFAULT_TIER, chatJid },
+      'Signal default tier template CLAUDE.md not found, skipping auto-registration',
+    );
+    return false;
+  }
+
+  const group: RegisteredGroup = {
+    name: displayName,
