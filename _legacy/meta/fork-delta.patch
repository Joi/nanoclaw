+    const claim: ClaimData = {
+      platform: 'slack',
+      workspace: 'henkaku',
+      user_id: 'U12345678',
+      display_name: 'Karma Chophel',
+      claimed_identity: 'Karma Chophel',
+      matched_people_file: 'people/karma-chophel.md',
