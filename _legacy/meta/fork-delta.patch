+      const groups = { 'target@g.us': testGroup };
+
+      await processMessageIpc(
+        {
+          type: 'file',
+          chatJid: 'target@g.us',
+          filePath: '/tmp/report.pdf',
+          filename: 'report.pdf',
+          mimetype: 'application/pdf',
+          caption: 'Here is the report',
+        },
+        'source-group',
+        true,
+        deps,
+        groups,
+      );
+
+      expect(deps.sendFile).toHaveBeenCalledWith(
