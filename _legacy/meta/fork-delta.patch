+  it('getNewMessages caps to limit and returns most recent in chronological order', () => {
+    const { messages, newTimestamp } = getNewMessages(
+      ['group@g.us'],
+      '2024-01-01T00:00:00.000Z',
+      'jibot',
+      3,
+    );
+    expect(messages).toHaveLength(3);
